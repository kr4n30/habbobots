# ── Server ──────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ─────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro
JWT_EXPIRES_IN=7d

# ── SQLite ───────────────────────────────
DB_PATH=./data/habbobots.db

# ── Discord OAuth ────────────────────────
DISCORD_CLIENT_ID=tu_discord_client_id
DISCORD_CLIENT_SECRET=tu_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback

# ── Frontend ─────────────────────────────
FRONTEND_URL=http://localhost:4321

# ── Email / SMTP ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion
SMTP_FROM=HabboBots <tu_email@gmail.com>

# ── Stripe ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Backend URL (para webhooks) ──────────
BACKEND_URL=http://localhost:3001

# ── PayPal ───────────────────
# ── Discord Webhooks ─────────────────────
# Webhook genérico (alertas del sistema, tickets)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/TU_WEBHOOK_AQUI
# Webhook específico para pedidos/servicios
DISCORD_WEBHOOK_ORDERS=https://discord.com/api/webhooks/TU_WEBHOOK_ORDERS
# Webhook específico para pagos
DISCORD_WEBHOOK_PAYMENTS=https://discord.com/api/webhooks/TU_WEBHOOK_PAYMENTS

# ── Bot VPS ──────────────────────────────
BOT_VPS_URL=http://localhost:5001
BOT_GUI_URL=http://localhost:5000

# ── Anti-multicuenta ─────────────────────
# Por defecto solo se permite 1 cuenta por IP.
# Pon 'true' para desactivar esta restricción (ej: en desarrollo local).
ALLOW_MULTIPLE_ACCOUNTS_PER_IP=false

# ── Push Notifications (PWA) ─────────────
# Genera las claves con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@habbobots.com
�� Discord Webhooks ─────────────────────
# Webhook genérico (fallback para todo si no se definen los específicos)
DISCORD_WEBHOOK_URL=
# Webhook específico para pedidos de servicios
DISCORD_WEBHOOK_ORDERS=
# Webhook específico para pagos recibidos
DISCORD_WEBHOOK_PAYMENTS=
