# ── Server ──────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ─────────────────────────────────
JWT_SECRET=CAMBIA_ESTO_POR_ALGO_LARGO_Y_ALEATORIO_minimo32chars
JWT_EXPIRES_IN=7d

# ── SQLite ───────────────────────────────
DB_PATH=./data/habbobots.db

# ── Discord OAuth ────────────────────────
DISCORD_CLIENT_ID=tu_discord_client_id
DISCORD_CLIENT_SECRET=tu_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback

# ── Frontend ─────────────────────────────
FRONTEND_URL=http://localhost:4321

# ── Stripe ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Bot VPS ──────────────────────────────
# headless_bot_manager.py → puerto 5001 (servicios automáticos)
BOT_VPS_URL=http://localhost:5001
BOT_VPS_API_KEY=clave_secreta_vps

# web.py (Flask GUI del bot) → puerto 5000 (panel admin manual)
BOT_GUI_URL=http://localhost:5000
