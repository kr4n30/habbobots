---
// Página pública — sin auth
const title = "Estado del Sistema · HabboBOTS";
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #080818;
      --card:     #0d1428;
      --border:   rgba(0,195,255,.14);
      --blue:     #00c3ff;
      --green:    #00ffa3;
      --yellow:   #ffbe00;
      --red:      #ff3c3c;
      --muted:    #6d7a9f;
      --text:     #c8d4f0;
    }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; min-height: 100vh; }

    header {
      border-bottom: 1px solid var(--border); padding: 1rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo { font-family:'Orbitron',sans-serif; font-size:1.1rem; color: var(--blue); letter-spacing:2px; }
    .back-link { color: var(--muted); font-size:.82rem; text-decoration:none; }
    .back-link:hover { color: var(--blue); }

    main { max-width: 760px; margin: 0 auto; padding: 2.5rem 1.5rem; }

    .page-title { font-family:'Orbitron',sans-serif; font-size:1.4rem; color:#fff; margin-bottom:.4rem; }
    .page-sub   { color: var(--muted); font-size:.88rem; margin-bottom: 2rem; }

    .overall-banner {
      border-radius: 12px; padding: 1rem 1.4rem;
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 2rem; font-weight: 700; font-size: .95rem;
      transition: background .3s;
    }
    .overall-ok      { background: rgba(0,255,163,.1); border:1px solid rgba(0,255,163,.3); color: var(--green); }
    .overall-warn    { background: rgba(255,190,0,.1);  border:1px solid rgba(255,190,0,.3);  color: var(--yellow); }
    .overall-down    { background: rgba(255,60,60,.1);  border:1px solid rgba(255,60,60,.3);  color: var(--red); }
    .overall-loading { background: rgba(0,195,255,.07); border:1px solid var(--border);        color: var(--muted); }
    .banner-dot { width:12px; height:12px; border-radius:50%; flex-shrink:0; }
    .dot-ok   { background: var(--green); box-shadow:0 0 8px var(--green); }
    .dot-warn { background: var(--yellow); }
    .dot-down { background: var(--red); box-shadow:0 0 8px var(--red); }
    .dot-load { background: var(--muted); }

    .section-label { font-size:.72rem; font-weight:700; letter-spacing:.8px; text-transform:uppercase; color: var(--muted); margin-bottom:.75rem; }

    .services-list { display: flex; flex-direction: column; gap: .55rem; margin-bottom: 2rem; }
    .srv-row {
      display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      background: var(--card); border: 1px solid var(--border); border-radius: 10px;
      padding: .8rem 1.1rem;
    }
    .srv-name  { font-weight: 600; color: #fff; font-size: .88rem; }
    .srv-desc  { font-size: .74rem; color: var(--muted); margin-top: .1rem; }
    .srv-badge {
      padding: .22rem .65rem; border-radius: 20px;
      font-size: .72rem; font-weight: 700; flex-shrink: 0;
    }
    .badge-online  { background:rgba(0,255,163,.12); color: var(--green); }
    .badge-offline { background:rgba(255,60,60,.1);  color: var(--red); }
    .badge-check   { background:rgba(0,195,255,.1);  color: var(--blue); }

    .stats-mini {
      display: grid; grid-template-columns: repeat(3,1fr); gap: .75rem;
      margin-bottom: 2rem;
    }
    .sm-card { background: var(--card); border:1px solid var(--border); border-radius:10px; padding:.9rem; text-align:center; }
    .sm-val  { font-family:'Orbitron',sans-serif; font-size:1.3rem; font-weight:800; color: var(--blue); }
    .sm-lbl  { font-size:.68rem; color: var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-top:.15rem; }

    .incidents { background: var(--card); border:1px solid var(--border); border-radius:10px; padding:1.2rem 1.4rem; }
    .inc-item  { display:flex; gap:.75rem; padding:.6rem 0; border-bottom:1px solid rgba(255,255,255,.05); }
    .inc-item:last-child { border-bottom: none; }
    .inc-dot   { width:8px; height:8px; border-radius:50%; margin-top:4px; flex-shrink:0; }
    .inc-title { font-weight:600; color:#fff; font-size:.85rem; }
    .inc-ts    { font-size:.72rem; color: var(--muted); }

    .refresh-note { text-align:center; color: var(--muted); font-size:.76rem; margin-top:1.5rem; }
    .refresh-btn  { background:none; border:none; color: var(--blue); cursor:pointer; font-size:.76rem; text-decoration:underline; }
  </style>
</head>
<body>
  <header>
    <div class="logo">HABBOBOTS</div>
    <a href="/" class="back-link">← Ir al inicio</a>
  </header>

  <main>
    <div class="page-title">Estado del sistema</div>
    <div class="page-sub">Actualización en tiempo real · Se refresca cada 30s</div>

    <div class="overall-banner overall-loading" id="overall-banner">
      <div class="banner-dot dot-load" id="banner-dot"></div>
      <span id="banner-text">Comprobando servicios…</span>
    </div>

    <div class="section-label">Servicios</div>
    <div class="services-list" id="services-list">
      <div class="srv-row"><div><div class="srv-name">Cargando…</div></div></div>
    </div>

    <div class="section-label">Estadísticas</div>
    <div class="stats-mini">
      <div class="sm-card"><div class="sm-val" id="stat-bots">—</div><div class="sm-lbl">Bots activos</div></div>
      <div class="sm-card"><div class="sm-val" id="stat-orders">—</div><div class="sm-lbl">Pedidos hoy</div></div>
      <div class="sm-card"><div class="sm-val" id="stat-uptime">—</div><div class="sm-lbl">Uptime</div></div>
    </div>

    <div class="section-label">Historial de incidencias (últimas 24h)</div>
    <div class="incidents" id="incidents">
      <div class="inc-item"><div class="inc-dot" style="background:var(--green)"></div><div><div class="inc-title">Sin incidencias registradas</div><div class="inc-ts">Sistema operando con normalidad</div></div></div>
    </div>

    <div class="refresh-note">
      Última actualización: <span id="last-updated">—</span> ·
      <button class="refresh-btn" onclick="loadStatus()">Actualizar ahora</button>
    </div>
  </main>

  <script>
    const SERVICES_META = {
      backend:     { name: 'API Backend',        desc: 'Node.js · Puerto 3001' },
      bot_manager: { name: 'Bot Manager',         desc: 'Python · Puerto 5001' },
      web_gui:     { name: 'Panel Admin Bots',    desc: 'Python · Puerto 5000' },
      database:    { name: 'Base de datos',       desc: 'SQLite' },
      frontend:    { name: 'Frontend Web',        desc: 'Astro · Puerto 4321' },
    };

    async function loadStatus() {
      try {
        const r = await fetch('/api/status');
        const d = await r.json();

        // Banner general
        const allOnline = d.services.every(s => s.status === 'online');
        const anyDown   = d.services.some(s  => s.status === 'offline');
        const banner    = document.getElementById('overall-banner');
        const dot       = document.getElementById('banner-dot');
        const text      = document.getElementById('banner-text');

        banner.className = `overall-banner ${allOnline ? 'overall-ok' : anyDown ? 'overall-down' : 'overall-warn'}`;
        dot.className    = `banner-dot ${allOnline ? 'dot-ok' : anyDown ? 'dot-down' : 'dot-warn'}`;
        text.textContent = allOnline
          ? '✅ Todos los sistemas operativos'
          : anyDown ? '🔴 Algunos servicios no responden'
          : '⚠️ Degradación parcial del servicio';

        // Lista de servicios
        const list = document.getElementById('services-list');
        list.innerHTML = d.services.map(s => {
          const meta   = SERVICES_META[s.id] || { name: s.id, desc: '' };
          const online = s.status === 'online';
          return `
            <div class="srv-row">
              <div>
                <div class="srv-name">${meta.name}</div>
                <div class="srv-desc">${meta.desc}${s.latency != null ? ` · ${s.latency}ms` : ''}</div>
              </div>
              <span class="srv-badge ${online ? 'badge-online' : 'badge-offline'}">
                ${online ? '● Operativo' : '● Caído'}
              </span>
            </div>`;
        }).join('');

        // Stats
        document.getElementById('stat-bots').textContent   = d.stats?.activeBots   ?? '—';
        document.getElementById('stat-orders').textContent = d.stats?.ordersToday   ?? '—';
        document.getElementById('stat-uptime').textContent = d.stats?.uptime        ?? '—';

        // Incidencias
        if (d.incidents?.length) {
          document.getElementById('incidents').innerHTML = d.incidents.map(i => `
            <div class="inc-item">
              <div class="inc-dot" style="background:${i.resolved ? 'var(--green)' : 'var(--red)'}"></div>
              <div>
                <div class="inc-title">${i.title}</div>
                <div class="inc-ts">${new Date(i.at).toLocaleString('es-ES')}</div>
              </div>
            </div>`).join('');
        }

        document.getElementById('last-updated').textContent = new Date().toLocaleTimeString('es-ES');
      } catch (e) {
        document.getElementById('banner-text').textContent = '⚠️ No se pudo obtener el estado';
      }
    }

    loadStatus();
    setInterval(loadStatus, 30_000);
  </script>
</body>
</html>
