---
import DashLayout from '../layouts/DashLayout.astro';
---
<DashLayout title="Mi Perfil" activePage="perfil">
  <style>
    .profile-grid {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 1.5rem;
    }
    .avatar-section {
      display: flex; flex-direction: column; align-items: center;
      padding: 2rem 1.25rem;
      text-align: center;
    }
    .habbo-avatar-frame {
      position: relative;
      width: 120px; height: 140px;
      margin-bottom: 1rem;
    }
    .habbo-avatar-frame img {
      width: 100%; height: 100%;
      object-fit: contain;
      image-rendering: pixelated;
    }
    .avatar-glow {
      position: absolute; inset: -8px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0,195,255,.25) 0%, transparent 70%);
      pointer-events: none;
    }
    .username { font-family:'Orbitron',sans-serif; font-size:1.1rem; font-weight:700; margin-bottom:.25rem; }
    .user-role { font-size:.78rem; color:var(--text-muted); margin-bottom:1rem; }
    .verified-badge {
      display:inline-flex; align-items:center; gap:.35rem;
      padding:.3rem .75rem;
      background:rgba(0,255,163,.1); border:1px solid rgba(0,255,163,.25);
      border-radius:50px; font-size:.75rem; font-weight:600; color:var(--success);
      margin-bottom:1.25rem;
    }
    .hotel-tag {
      display:inline-flex; align-items:center; gap:.35rem;
      padding:.2rem .6rem; border-radius:4px; font-size:.75rem; font-weight:600;
      background:rgba(0,195,255,.1); border:1px solid rgba(0,195,255,.2);
      color:var(--blue-primary); margin:.15rem;
    }
    .profile-stats {
      display: grid; grid-template-columns:1fr 1fr;
      gap: .75rem; margin-top:1rem; width:100%;
    }
    .profile-stat {
      padding:.75rem; text-align:center;
      background:rgba(0,0,0,.3); border-radius:8px;
      border:1px solid rgba(255,255,255,.05);
    }
    .profile-stat-val { font-family:'Orbitron',sans-serif; font-size:1.2rem; font-weight:700; }
    .profile-stat-lbl { font-size:.68rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.5px; margin-top:.15rem; }

    /* Motto verification */
    .motto-code {
      font-family:'Orbitron',sans-serif; font-size:.95rem;
      padding:.6rem 1rem;
      background:rgba(0,0,0,.4); border:1px dashed rgba(0,195,255,.4);
      border-radius:6px; color:var(--blue-primary);
      letter-spacing:2px; text-align:center;
      cursor:pointer; transition:border-color .2s;
    }
    .motto-code:hover { border-color:var(--blue-primary); }
    .motto-steps { list-style:none; counter-reset:step; }
    .motto-steps li {
      counter-increment: step;
      display:flex; align-items:flex-start; gap:.75rem;
      padding:.6rem 0; border-bottom:1px solid rgba(255,255,255,.04);
      font-size:.86rem; color:var(--text-secondary);
    }
    .motto-steps li:last-child { border-bottom:none; }
    .motto-steps li::before {
      content: counter(step);
      width:22px; height:22px; border-radius:50%;
      background: var(--gradient-main);
      color:#fff; font-size:.72rem; font-weight:700;
      display:flex; align-items:center; justify-content:center;
      flex-shrink:0; margin-top:.05rem;
    }

    @media (max-width:900px) { .profile-grid { grid-template-columns:1fr; } }
  </style>

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;">
    <div>
      <h1 style="font-family:'Orbitron',sans-serif;font-size:1.25rem;font-weight:700;">Mi Perfil</h1>
      <p style="color:var(--text-muted);font-size:.86rem;margin-top:.2rem;">Gestiona tu identidad y verificación Habbo</p>
    </div>
    <a href="/ajustes" class="hb-btn">Ajustes</a>
  </div>

  <div class="profile-grid">

    <!-- Left: Avatar & stats -->
    <div class="hb-window">
      <div class="hb-window-title">
        <h3>Mi cuenta</h3>
        <span class="hb-minimize">–</span>
      </div>
      <div class="hb-window-body">
        <div class="avatar-section">
          <div class="habbo-avatar-frame">
            <div class="avatar-glow"></div>
            <img
              id="habbo-avatar"
              src="https://sandbox.habbo.com/habbo-imaging/avatarimage?figure=hd-180-1369.ch-210-1408.lg-4315.ha-4313.he-1605-1408.cc-4314&gender=M&direction=3&head_direction=3&action=&gesture=nrm&size=l"
              alt="Avatar Habbo"
              onerror="this.src='https://ui-avatars.com/api/?name=Rafa&background=0080ff&color=fff&size=120&rounded=true'"
            />
          </div>
          <div class="username gradient-text">Rafa</div>
          <div class="user-role">Miembro · Plan Básico</div>
          <div class="verified-badge">
            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Verificado en habbo.es
          </div>

          <div>
            <span class="hotel-tag">habbo.es</span>
            <span class="hotel-tag">habbo.com</span>
          </div>

          <div class="profile-stats">
            <div class="profile-stat">
              <div class="profile-stat-val neon-blue">3</div>
              <div class="profile-stat-lbl">Bots</div>
            </div>
            <div class="profile-stat">
              <div class="profile-stat-val neon-purple">1,240</div>
              <div class="profile-stat-lbl">Créditos</div>
            </div>
            <div class="profile-stat">
              <div class="profile-stat-val" style="color:var(--success);">47</div>
              <div class="profile-stat-lbl">Días activo</div>
            </div>
            <div class="profile-stat">
              <div class="profile-stat-val" style="color:var(--warning);">8</div>
              <div class="profile-stat-lbl">Compras</div>
            </div>
          </div>

          <div style="margin-top:1.25rem;width:100%;">
            <a href="/tienda" class="hb-btn hb-btn-purple" style="display:flex;align-items:center;justify-content:center;gap:.4rem;width:100%;">
              💎 Comprar créditos
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Info & verification -->
    <div style="display:flex;flex-direction:column;gap:1.25rem;">

      <!-- Account info -->
      <div class="hb-window">
        <div class="hb-window-title"><h3>Información de cuenta</h3><span class="hb-close" onclick="showToast('Edición en desarrollo','info')">✕</span></div>
        <div class="hb-window-body">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
              <label class="form-label">Usuario</label>
              <input type="text" class="form-input" value="Rafa" />
            </div>
            <div class="form-group">
              <label class="form-label">Email</label>
              <input type="email" class="form-input" value="roalillo98@gmail.com" />
            </div>
            <div class="form-group">
              <label class="form-label">Usuario Habbo (habbo.es)</label>
              <input type="text" class="form-input" value="HabboRafa98" />
            </div>
            <div class="form-group">
              <label class="form-label">Cuenta creada</label>
              <input type="text" class="form-input" value="Junio 2026" readonly style="opacity:.6;" />
            </div>
          </div>
          <div style="margin-top:.5rem;display:flex;gap:.5rem;justify-content:flex-end;">
            <button class="hb-btn hb-btn-ghost" onclick="showToast('Cambios descartados','warning')">Cancelar</button>
            <button class="hb-btn" onclick="showToast('Perfil actualizado','success')">Guardar cambios</button>
          </div>
        </div>
      </div>

      <!-- Habbo verification -->
      <div class="hb-window">
        <div class="hb-window-title" style="background:linear-gradient(90deg,#0a4a1e,#061a0e);">
          <h3>🛡 Verificación Habbo por Motto</h3>
        </div>
        <div class="hb-window-body">
          <p style="font-size:.86rem;color:var(--text-secondary);margin-bottom:1rem;">
            Demuestra que eres el dueño de tu cuenta Habbo cambiando temporalmente tu motto a este código:
          </p>

          <div class="motto-code" onclick="copyToClipboard('HB-VERIFY-K9X4M2')" title="Clic para copiar">
            HB-VERIFY-K9X4M2
          </div>
          <p style="font-size:.72rem;color:var(--text-muted);text-align:center;margin-top:.35rem;">Clic para copiar · Caduca en 10 minutos</p>

          <ul class="motto-steps" style="margin-top:1rem;">
            <li>Abre Habbo en <strong>habbo.es</strong> con tu cuenta</li>
            <li>Ve a tu perfil y cambia el motto al código de arriba</li>
            <li>Pulsa "Verificar ahora" — lo comprobamos automáticamente via API</li>
          </ul>

          <div style="margin-top:1rem;display:flex;gap:.5rem;">
            <button class="hb-btn" style="flex:1;" onclick="startVerification()">
              ✓ Verificar ahora
            </button>
            <button class="hb-btn hb-btn-ghost" onclick="generateNewCode()">Nuevo código</button>
          </div>
        </div>
      </div>

      <!-- Change password -->
      <div class="hb-window">
        <div class="hb-window-title"><h3>Cambiar contraseña</h3></div>
        <div class="hb-window-body">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:.85rem;">
            <div class="form-group">
              <label class="form-label">Actual</label>
              <input type="password" class="form-input" placeholder="••••••••" />
            </div>
            <div class="form-group">
              <label class="form-label">Nueva</label>
              <input type="password" class="form-input" placeholder="••••••••" />
            </div>
            <div class="form-group">
              <label class="form-label">Confirmar</label>
              <input type="password" class="form-input" placeholder="••••••••" />
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end;">
            <button class="hb-btn" onclick="showToast('Contraseña actualizada','success')">Cambiar contraseña</button>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script is:inline slot="scripts">
    let profileHotel = 'es'; // hotel por defecto para verificación en perfil

    // ── Load real user data ────────────────────────
    (async () => {
      try {
        const { user } = await UsersAPI.me();
        // Nombre de usuario en el encabezado
        const usernameEl = document.querySelector('.username');
        if (usernameEl) usernameEl.textContent = user.username;
        // Actualiza los inputs del formulario
        const inputs = document.querySelectorAll('.form-input');
        if (inputs[0]) inputs[0].value = user.username;
        if (inputs[1]) inputs[1].value = user.email;
        if (user.habbo_user && inputs[2]) inputs[2].value = user.habbo_user;
        if (user.created_at && inputs[3]) {
          inputs[3].value = new Date(user.created_at).toLocaleDateString('es-ES', { year: 'numeric', month: 'long' });
        }
        // Créditos en las estadísticas del perfil
        const creditStat = document.querySelector('.profile-stat-val.neon-purple');
        if (creditStat) creditStat.textContent = user.credits.toLocaleString();
      } catch (err) {
        if (err && err.status === 401) AuthAPI.logout();
      }

      // Load verified accounts
      try {
        const { accounts } = await HabboAPI.accounts();
        if (accounts.length > 0) {
          // Update hotel tags
          const tagContainer = document.querySelector('.verified-badge').parentElement;
          const existingTags = tagContainer.querySelectorAll('.hotel-tag');
          existingTags.forEach(t => t.remove());
          accounts.forEach(a => {
            const span = document.createElement('span');
            span.className = 'hotel-tag';
            span.textContent = 'habbo.' + a.hotel;
            tagContainer.appendChild(span);
          });
          profileHotel = accounts[0].hotel; // usar el primer hotel verificado para verificación
        }
      } catch {}

      // Request verification code on load
      try {
        const res = await HabboAPI.requestVerify(profileHotel);
        if (res.token) {
          document.querySelector('.motto-code').textContent = res.token;
        }
      } catch {}
    })();

    // ── Verificación ───────────────────────────────
    async function startVerification() {
      const inputs = document.querySelectorAll('.form-input');
      const habboName = inputs[2] ? inputs[2].value.trim() : '';
      if (!habboName) { showToast('Introduce tu usuario de Habbo en el formulario', 'warning'); return; }
      showToast(`Verificando motto en habbo.${profileHotel}…`, 'info');
      try {
        await HabboAPI.checkVerify(habboName, profileHotel);
        showToast('✓ Cuenta verificada correctamente', 'success');
      } catch (err) {
        showToast(err.message || '¿Cambiaste el motto? Inténtalo de nuevo.', 'danger');
      }
    }

    async function generateNewCode() {
      try {
        const res = await HabboAPI.requestVerify(profileHotel);
        document.querySelector('.motto-code').textContent = res.token || 'HB-VERIFY-ERROR';
        showToast('Nuevo código generado', 'info');
      } catch (err) {
        showToast(err.message || 'Error al generar código', 'danger');
      }
    }
  </script>
</DashLayout>
