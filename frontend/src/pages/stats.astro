---
import DashLayout from '../layouts/DashLayout.astro';
---
<DashLayout title="Estadísticas" activePage="stats">
  <style>
    .stats-hero {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
      gap: .85rem;
      margin-bottom: 1.75rem;
    }
    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border-glow);
      border-radius: 12px;
      padding: 1.1rem 1.2rem;
      text-align: center;
    }
    .stat-val {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.6rem;
      font-weight: 800;
      line-height: 1;
    }
    .stat-lbl {
      font-size: .72rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: .7px;
      margin-top: .4rem;
    }
    .lb-wrap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
    @media (max-width: 768px) { .lb-wrap { grid-template-columns: 1fr; } }
    .lb-card { background: var(--bg-card); border: 1px solid var(--border-glow); border-radius: 12px; overflow: hidden; }
    .lb-header {
      padding: .85rem 1.1rem;
      border-bottom: 1px solid rgba(255,255,255,.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .lb-title { font-family: 'Orbitron', sans-serif; font-size: .8rem; font-weight: 700; }
    .lb-select {
      background: rgba(0,0,0,.3);
      border: 1px solid var(--border-glow);
      border-radius: 6px;
      color: #fff;
      font-size: .78rem;
      padding: .25rem .55rem;
      cursor: pointer;
    }
    .lb-row {
      display: flex;
      align-items: center;
      gap: .85rem;
      padding: .7rem 1.1rem;
      border-bottom: 1px solid rgba(255,255,255,.04);
      transition: background .1s;
    }
    .lb-row:last-child { border-bottom: none; }
    .lb-row:hover { background: rgba(255,255,255,.02); }
    .lb-rank {
      font-family: 'Orbitron', sans-serif;
      font-size: .8rem;
      font-weight: 800;
      width: 26px;
      text-align: center;
      flex-shrink: 0;
    }
    .rank-1 { color: #FFD700; }
    .rank-2 { color: #C0C0C0; }
    .rank-3 { color: #CD7F32; }
    .rank-other { color: var(--text-muted); }
    .lb-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: rgba(0,195,255,.12); border: 1px solid rgba(0,195,255,.2);
      display: flex; align-items: center; justify-content: center;
      font-size: .85rem; font-weight: 700; flex-shrink: 0; overflow: hidden;
    }
    .lb-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .lb-name { flex: 1; font-weight: 600; font-size: .88rem; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .lb-nick { font-size: .72rem; color: var(--text-muted); }
    .lb-val { font-family: 'Orbitron', sans-serif; font-size: .85rem; font-weight: 700; flex-shrink: 0; }
    .activity-wrap {
      background: var(--bg-card); border: 1px solid var(--border-glow);
      border-radius: 12px; padding: 1.25rem 1.4rem; margin-bottom: 1.25rem;
    }
    .activity-title { font-family: 'Orbitron', sans-serif; font-size: .82rem; font-weight: 700; margin-bottom: 1rem; }
    .chart-bars { display: flex; align-items: flex-end; gap: 3px; height: 80px; }
    .chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%; justify-content: flex-end; }
    .chart-bar { width: 100%; min-height: 2px; border-radius: 3px 3px 0 0; background: var(--blue-primary); opacity: .7; transition: opacity .15s; cursor: default; }
    .chart-bar:hover { opacity: 1; }
    .chart-day { font-size: .6rem; color: var(--text-muted); text-align: center; white-space: nowrap; overflow: hidden; }
  </style>

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:.5rem;">
    <div>
      <h1 style="font-family:'Orbitron',sans-serif;font-size:1.2rem;font-weight:700;margin:0;">Estadísticas</h1>
      <p style="color:var(--text-muted);font-size:.82rem;margin:.2rem 0 0;">Actividad de la plataforma en tiempo real</p>
    </div>
    <select id="hotel-filter" class="lb-select" style="font-size:.82rem;padding:.35rem .7rem;" onchange="onHotelChange()">
      <option value="">Todos los hoteles</option>
      <option value="es">habbo.es</option>
      <option value="com">habbo.com</option>
      <option value="br">habbo.com.br</option>
      <option value="tr">habbo.com.tr</option>
      <option value="fi">habbo.fi</option>
      <option value="de">habbo.de</option>
    </select>
  </div>

  <!-- Hero stats -->
  <div class="stats-hero">
    <div class="stat-card"><div class="stat-val neon-blue" id="st-users">—</div><div class="stat-lbl">Usuarios totales</div></div>
    <div class="stat-card"><div class="stat-val" style="color:var(--success);" id="st-orders">—</div><div class="stat-lbl">Pedidos completados</div></div>
    <div class="stat-card"><div class="stat-val neon-purple" id="st-credits">—</div><div class="stat-lbl">Créditos en circulación</div></div>
    <div class="stat-card"><div class="stat-val" style="color:var(--warning);" id="st-bots">—</div><div class="stat-lbl">Bots activos</div></div>
    <div class="stat-card"><div class="stat-val" style="color:#ffc107;" id="st-rating">—</div><div class="stat-lbl">Valoración media</div></div>
    <div class="stat-card"><div class="stat-val" style="color:var(--blue-primary);" id="st-pending">—</div><div class="stat-lbl">En proceso</div></div>
  </div>

  <!-- Activity chart -->
  <div class="activity-wrap">
    <div class="activity-title">Actividad últimos 30 días <span style="color:var(--text-muted);font-size:.72rem;font-family:sans-serif;font-weight:400;">(pedidos por día)</span></div>
    <div class="chart-bars" id="activity-chart">
      <div style="color:var(--text-muted);font-size:.82rem;align-self:center;margin:auto;">Cargando…</div>
    </div>
  </div>

  <!-- Leaderboards -->
  <div class="lb-wrap">
    <div class="lb-card">
      <div class="lb-header">
        <span class="lb-title">🏆 Top usuarios</span>
        <select class="lb-select" id="lb-by" onchange="loadLeaderboard()">
          <option value="orders">Por pedidos</option>
          <option value="credits">Por créditos gastados</option>
        </select>
      </div>
      <div id="lb-users"><div style="text-align:center;padding:2rem;color:var(--text-muted);">Cargando…</div></div>
    </div>

    <div class="lb-card">
      <div class="lb-header">
        <span class="lb-title">🛒 Servicios más pedidos</span>
      </div>
      <div id="lb-products"><div style="text-align:center;padding:2rem;color:var(--text-muted);">Cargando…</div></div>
    </div>
  </div>

  <script is:inline>
    let _hotel = '';

    function onHotelChange() {
      _hotel = document.getElementById('hotel-filter').value;
      loadAll();
    }

    async function loadAll() {
      loadStats();
      loadActivity();
      loadLeaderboard();
      loadProductRanking();
    }

    async function loadStats() {
      try {
        const d = await StatsAPI.overview();
        set('st-users',   (d.totalUsers   || 0).toLocaleString());
        set('st-orders',  (d.completedOrders || 0).toLocaleString());
        set('st-credits', (d.creditsInCirculation || d.totalCredits || 0).toLocaleString());
        set('st-bots',    (d.activeBots   || 0).toLocaleString());
        set('st-rating',  d.avgRating ? `${d.avgRating} ⭐` : '—');
        set('st-pending', (d.pendingOrders || 0).toLocaleString());
      } catch (e) { console.error('stats:', e); }
    }

    async function loadActivity() {
      try {
        const d    = await StatsAPI.activity(30);
        const days = d.activity || [];
        if (!days.length) return;
        const max   = Math.max(...days.map(d => d.count), 1);
        const chart = document.getElementById('activity-chart');
        chart.innerHTML = days.map(day => {
          const h     = Math.max(4, Math.round((day.count / max) * 76));
          return `<div class="chart-bar-wrap" title="${day.date}: ${day.count} pedidos">
            <div class="chart-bar" style="height:${h}px;"></div>
            <div class="chart-day">${day.count > 0 ? day.count : ''}</div>
          </div>`;
        }).join('');
      } catch (e) { console.error('activity:', e); }
    }

    async function loadLeaderboard() {
      const by = document.getElementById('lb-by').value;
      const el = document.getElementById('lb-users');
      el.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--text-muted);">Cargando…</div>';
      try {
        const d     = await StatsAPI.leaderboard(by, _hotel || undefined);
        const users = d.leaderboard || d.users || [];
        if (!users.length) { el.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--text-muted);">Sin datos</div>'; return; }
        el.innerHTML = users.slice(0, 10).map((u, i) => {
          const rank      = i + 1;
          const rankClass = rank === 1 ? 'rank-1' : rank === 2 ? 'rank-2' : rank === 3 ? 'rank-3' : 'rank-other';
          const val       = by === 'credits'
            ? `${(u.credits_spent || u.total_credits || 0).toLocaleString()} cr`
            : `${u.total_orders || 0} pedidos`;
          const initials  = (u.username || '?').slice(0, 2).toUpperCase();
          return `<div class="lb-row">
            <div class="lb-rank ${rankClass}">${rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : `#${rank}`}</div>
            <div class="lb-avatar">${u.avatar_url ? `<img src="${u.avatar_url}" alt="${initials}" />` : initials}</div>
            <div style="flex:1;min-width:0;">
              <div class="lb-name">${u.username}</div>
              ${u.habbo_name ? `<div class="lb-nick">🎮 ${u.habbo_name}</div>` : ''}
            </div>
            <div class="lb-val" style="color:var(--purple-primary);">${val}</div>
          </div>`;
        }).join('');
      } catch (e) { el.innerHTML = `<div style="text-align:center;padding:2rem;color:var(--danger);">${e.message}</div>`; }
    }

    async function loadProductRanking() {
      const el = document.getElementById('lb-products');
      try {
        const d        = await StatsAPI.overview();
        const products = d.topProducts || [];
        if (!products.length) { el.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--text-muted);">Sin datos</div>'; return; }
        el.innerHTML = products.slice(0, 10).map((p, i) => {
          const rank = i + 1;
          return `<div class="lb-row">
            <div class="lb-rank ${rank<=3?['rank-1','rank-2','rank-3'][rank-1]:'rank-other'}">${rank<=3?['🥇','🥈','🥉'][rank-1]:`#${rank}`}</div>
            <div style="flex:1;min-width:0;">
              <div class="lb-name">${p.name}</div>
              <div class="lb-nick">${p.hotel ? `habbo.${p.hotel}` : 'Todos los hoteles'}</div>
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <div class="lb-val" style="color:var(--blue-primary);font-size:.8rem;">${p.total_orders||0} pedidos</div>
              <div style="font-size:.72rem;color:var(--success);">${(p.total_revenue||0).toLocaleString()} cr</div>
            </div>
          </div>`;
        }).join('');
      } catch (e) { el.innerHTML = `<div style="text-align:center;padding:2rem;color:var(--danger);">${e.message}</div>`; }
    }

    function set(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }

    loadAll();
  </script>
</DashLayout>
