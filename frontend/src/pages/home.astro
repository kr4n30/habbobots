---
import DashLayout from '../layouts/DashLayout.astro';
---
<DashLayout title="Inicio" activePage="home">
  <style>
    /* ── Bienvenida ─────────────────────────────────── */
    .welcome-bar {
      display: flex; align-items: center; gap: 1.25rem;
      padding: 1.25rem 1.5rem;
      background: linear-gradient(135deg, rgba(0,60,120,.35), rgba(80,0,160,.25));
      border: 1px solid rgba(0,195,255,.15);
      border-radius: 14px;
      margin-bottom: 1.75rem;
      position: relative; overflow: hidden;
    }
    .welcome-bar::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(90deg, rgba(0,195,255,.05), transparent);
      pointer-events: none;
    }
    .welcome-avatar {
      width: 200px; height: 40px;
      border-radius: 8px;
      border: 1px solid rgba(0,195,255,.25);
      background: rgba(0,0,0,.3);
      flex-shrink: 0;
      overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .welcome-avatar img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
    .welcome-text h2 {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.15rem; font-weight: 700; margin: 0 0 .25rem;
    }
    .welcome-text p { color: var(--text-muted); font-size: .85rem; margin: 0; }
    .welcome-credits {
      margin-left: auto; text-align: right; flex-shrink: 0;
    }
    .credits-amount {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.6rem; font-weight: 800;
      background: var(--gradient-main); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
      display: block;
    }
    .credits-label { font-size: .72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
    .btn-buy-credits {
      display: inline-flex; align-items: center; gap: .4rem;
      margin-top: .5rem; padding: .35rem .85rem;
      background: rgba(155,48,255,.15); border: 1px solid rgba(155,48,255,.3);
      border-radius: 6px; color: var(--purple-primary);
      font-size: .78rem; font-weight: 600; cursor: pointer;
      text-decoration: none; transition: all .2s;
    }
    .btn-buy-credits:hover { background: rgba(155,48,255,.25); }

    /* ── Sección títulos ────────────────────────────── */
    .section-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1rem;
    }
    .section-title {
      font-family: 'Orbitron', sans-serif;
      font-size: .95rem; font-weight: 700; letter-spacing: .5px;
    }
    .section-link {
      font-size: .8rem; color: var(--blue-primary); text-decoration: none;
    }
    .section-link:hover { text-decoration: underline; }

    /* ── Grid de productos ──────────────────────────── */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .product-card {
      background: var(--bg-card); border: 1px solid var(--border-glow);
      border-radius: 12px; overflow: hidden;
      display: flex; flex-direction: column;
      transition: border-color .2s, transform .15s;
      cursor: pointer;
    }
    .product-card:hover {
      border-color: rgba(0,195,255,.35);
      transform: translateY(-2px);
    }
    .product-banner {
      width: 100%; height: 110px;
      object-fit: cover; display: block;
      border-bottom: 1px solid var(--border-glow);
    }
    .product-banner-fallback {
      width: 100%; height: 110px;
      display: flex; align-items: center; justify-content: center;
      font-size: 2rem;
    }
    .product-body { padding: .9rem 1rem; display: flex; flex-direction: column; gap: .45rem; flex: 1; }
    .product-icon {
      width: 42px; height: 42px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
    }
    .product-name { font-size: .9rem; font-weight: 700; color: #fff; margin: 0; }
    .product-desc { font-size: .78rem; color: var(--text-muted); line-height: 1.4; margin: 0; }
    .product-footer {
      display: flex; align-items: center; justify-content: space-between;
      margin-top: auto; padding-top: .5rem;
      border-top: 1px solid var(--border-glow);
    }
    .product-price {
      font-family: 'Orbitron', sans-serif; font-size: .9rem; font-weight: 800;
      color: var(--purple-primary);
    }
    .product-price span { font-size: .65rem; font-weight: 400; color: var(--text-muted); }
    .btn-order {
      padding: .3rem .75rem;
      background: rgba(0,195,255,.1); border: 1px solid rgba(0,195,255,.25);
      border-radius: 6px; color: var(--blue-primary);
      font-size: .75rem; font-weight: 600; cursor: pointer;
      transition: all .15s;
    }
    .btn-order:hover { background: rgba(0,195,255,.2); }

    /* ── Modal producto header ──────────────────────── */
    .modal-product-header {
      display: flex; align-items: center; gap: .85rem;
      margin-bottom: 1.1rem;
    }
    .modal-product-thumb {
      width: 54px; height: 40px; border-radius: 8px;
      object-fit: cover; border: 1px solid rgba(0,195,255,.2);
      flex-shrink: 0;
    }
    .modal-product-thumb-fallback {
      width: 54px; height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; flex-shrink: 0;
    }

    /* ── Modal pedido ───────────────────────────────── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.75); backdrop-filter: blur(6px);
      z-index: 200; align-items: center; justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: #0d1428; border: 1px solid rgba(0,195,255,.2);
      border-radius: 14px; width: 100%; max-width: 440px;
      padding: 1.75rem; position: relative;
    }
    .modal-title { font-family: 'Orbitron', sans-serif; font-size: 1rem; font-weight: 700; margin: 0 0 1.25rem; }
    .modal-close {
      position: absolute; top: 1rem; right: 1rem;
      background: none; border: none; color: var(--text-muted);
      font-size: 1.4rem; cursor: pointer; line-height: 1;
    }

    /* ── Pedidos recientes ──────────────────────────── */
    .orders-list { display: flex; flex-direction: column; gap: .65rem; }
    .order-row {
      display: flex; align-items: center; gap: 1rem;
      padding: .85rem 1rem;
      background: var(--bg-card); border: 1px solid var(--border-glow);
      border-radius: 10px;
    }
    .order-icon {
      width: 36px; height: 36px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; flex-shrink: 0;
    }
    .order-info { flex: 1; min-width: 0; }
    .order-name { font-size: .88rem; font-weight: 600; color: #fff; }
    .order-meta { font-size: .75rem; color: var(--text-muted); }
    .order-badge {
      padding: .2rem .55rem; border-radius: 20px;
      font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
    }
    .badge-pending   { background: rgba(255,190,0,.15); color: var(--warning); }
    .badge-active    { background: rgba(0,255,163,.12); color: var(--success); }
    .badge-completed { background: rgba(100,100,150,.15); color: var(--text-muted); }
    .badge-cancelled { background: rgba(255,60,60,.1);  color: var(--danger); }

    .empty-state {
      text-align: center; padding: 2.5rem 1rem;
      color: var(--text-muted); font-size: .88rem;
    }
    .empty-state p { margin: .5rem 0 0; }

    /* ── Servicios activos ──────────────────────────── */
    .active-card {
      display: flex; align-items: center; gap: 1rem;
      padding: .85rem 1rem;
      background: linear-gradient(135deg, rgba(0,255,163,.04), rgba(0,195,255,.04));
      border: 1px solid rgba(0,255,163,.2);
      border-radius: 10px;
      transition: border-color .2s;
    }
    .active-card:hover { border-color: rgba(0,255,163,.4); }
    .active-icon {
      width: 38px; height: 38px; border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem; flex-shrink: 0;
    }
    .active-info { flex: 1; min-width: 0; }
    .active-name { font-size: .9rem; font-weight: 700; color: #fff; }
    .active-meta { font-size: .73rem; color: var(--text-muted); margin-top: .1rem; }
    .active-time {
      font-family: 'Orbitron', sans-serif; font-size: .8rem; font-weight: 700;
      color: var(--success); white-space: nowrap;
    }
    .active-time.expiring { color: var(--warning); }
    .active-progress {
      width: 100%; height: 3px; background: rgba(255,255,255,.08);
      border-radius: 2px; margin-top: .5rem; overflow: hidden;
    }
    .active-progress-bar { height: 100%; background: var(--success); border-radius: 2px; transition: width .5s; }
    .btn-stop {
      padding: .3rem .7rem; background: rgba(255,60,60,.1);
      border: 1px solid rgba(255,60,60,.25); border-radius: 6px;
      color: var(--danger); font-size: .72rem; font-weight: 600;
      cursor: pointer; flex-shrink: 0; transition: all .15s;
    }
    .btn-stop:hover { background: rgba(255,60,60,.2); }
    @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.3)} }

    @media (max-width: 768px) {
      .welcome-bar { flex-wrap: wrap; }
      .welcome-credits { margin-left: 0; text-align: left; }
      .products-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .products-grid { grid-template-columns: 1fr; }
    }
  </style>

  <!-- Bienvenida -->
  <div class="welcome-bar">
    <div class="welcome-avatar">
      <img id="habbo-avatar" src="" alt="Avatar" style="display:none;" />
      <svg id="habbo-avatar-fallback" width="48" height="48" fill="none" stroke="rgba(0,195,255,.4)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </div>
    <div class="welcome-text">
      <h2>¡Hola, <span id="welcome-name">—</span>!</h2>
      <p id="welcome-sub">Elige un servicio y ponlo en marcha hoy</p>
    </div>
    <div class="welcome-credits">
      <span class="credits-amount" id="home-credits">—</span>
      <span class="credits-label">créditos</span>
      <br>
      <a href="/tienda" class="btn-buy-credits">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Conseguir créditos
      </a>
    </div>
  </div>

  <!-- ── Servicios y bots activos ──────────────── -->
  <div id="active-section" style="display:none;margin-bottom:1.75rem;">
    <div class="section-header">
      <h2 class="section-title" style="display:flex;align-items:center;gap:.5rem;">
        <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--success);animation:pulse-dot 1.5s ease-in-out infinite;"></span>
        Activos ahora
      </h2>
      <a href="/servicios#historial" class="section-link">Ver todo →</a>
    </div>
    <div id="active-list" style="display:flex;flex-direction:column;gap:.6rem;"></div>
  </div>

  <!-- Servicios disponibles -->
  <div class="section-header">
    <h2 class="section-title">Servicios disponibles</h2>
    <a href="/servicios" class="section-link">Ver todos →</a>
  </div>
  <div class="products-grid" id="products-grid">
    <!-- cargado por JS -->
    <div class="empty-state" style="grid-column:1/-1;">
      <div class="spinner" style="width:28px;height:28px;margin:0 auto;border:3px solid rgba(0,195,255,.2);border-top-color:#00c3ff;border-radius:50%;animation:spin .8s linear infinite;"></div>
    </div>
  </div>

  <!-- Mis pedidos recientes -->
  <div class="section-header">
    <h2 class="section-title">Mis pedidos recientes</h2>
    <a href="/servicios#historial" class="section-link">Ver historial →</a>
  </div>
  <div class="orders-list" id="orders-list">
    <div class="empty-state">
      <div class="spinner" style="width:24px;height:24px;margin:0 auto;border:3px solid rgba(0,195,255,.2);border-top-color:#00c3ff;border-radius:50%;animation:spin .8s linear infinite;"></div>
    </div>
  </div>

  <!-- Modal pedido -->
  <div class="modal-overlay" id="order-modal">
    <div class="modal-box">
      <button class="modal-close" onclick="closeModal()">×</button>
      <!-- Header con imagen + nombre del producto -->
      <div class="modal-product-header">
        <img id="modal-product-img" class="modal-product-thumb" src="" alt="" style="display:none;" />
        <div id="modal-product-icon-fb" class="modal-product-thumb-fallback" style="display:none;"></div>
        <div>
          <h3 class="modal-title" id="modal-product-name" style="margin:0;font-size:.95rem;">Pedir servicio</h3>
          <p id="modal-product-desc" style="font-size:.75rem;color:var(--text-muted);margin:.15rem 0 0;"></p>
        </div>
      </div>
      <div class="form-group" style="margin-bottom:.85rem;">
        <label class="form-label">Hotel</label>
        <select id="modal-hotel" class="form-input" style="cursor:pointer;">
          <option value="es">habbo.es</option>
          <option value="com">habbo.com</option>
          <option value="br">habbo.com.br</option>
          <option value="tr">habbo.com.tr</option>
          <option value="fi">habbo.fi</option>
          <option value="de">habbo.de</option>
          <option value="fr">habbo.fr</option>
          <option value="it">habbo.it</option>
          <option value="nl">habbo.nl</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:.85rem;">
        <label class="form-label">Nick de Habbo</label>
        <input type="text" id="modal-habbo" class="form-input" placeholder="TuNickEnHabbo" />
      </div>
      <!-- Solo para room_fill / raid: sala + duración y bots -->
      <div id="modal-roomfill-opts" style="display:none;">
        <div class="form-group" style="margin-bottom:.85rem;">
          <label class="form-label">ID de sala <span style="color:var(--text-muted);font-weight:400;">(sala donde entrarán los bots)</span></label>
          <input type="text" id="modal-room-id" class="form-input" placeholder="Ej: 12345678" />
        </div>
        <div class="form-group" style="margin-bottom:.85rem;">
          <label class="form-label">Duración</label>
          <select id="modal-duration" class="form-input" onchange="updateRoomFillPrice()" style="cursor:pointer;">
            <option value="1">1 hora</option>
            <option value="6">6 horas</option>
            <option value="24">1 día</option>
            <option value="72">3 días</option>
          </select>
        </div>
        <div class="form-group" style="margin-bottom:.85rem;">
          <label class="form-label">Cantidad de bots</label>
          <select id="modal-bots" class="form-input" onchange="updateRoomFillPrice()" style="cursor:pointer;">
            <option value="5">5 bots</option>
            <option value="10">10 bots</option>
            <option value="20">20 bots</option>
            <option value="50">50 bots</option>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin-bottom:1.25rem;">
        <label class="form-label">Notas (opcional)</label>
        <input type="text" id="modal-notes" class="form-input" placeholder="Ej: mascota Fluffy, personaje concreto…" />
      </div>
      <p style="font-size:.8rem;color:var(--text-muted);margin-bottom:1rem;">
        Coste: <strong id="modal-price" style="color:var(--purple-primary);font-family:'Orbitron',sans-serif;"></strong> créditos
        · Tu saldo: <strong id="modal-balance" style="color:var(--blue-primary);font-family:'Orbitron',sans-serif;"></strong>
      </p>
      <button class="btn btn-primary" style="width:100%;" id="modal-confirm-btn" onclick="confirmOrder()">
        Confirmar pedido
      </button>
    </div>
  </div>

  <script is:inline src="/js/api.js"></script>
  <script is:inline>
    if (!Auth.isLoggedIn()) window.location.href = '/';

    const PRODUCT_ICONS = {
      badge_respect: '👑',
      badge_pet:     '🐾',
      room_fill:     '🏠',
      raid:          '⚡',
      trade:         '💱',
      custom:        '✨',
    };
    const ICON_COLORS = {
      badge_respect: 'rgba(255,190,0,.15)',
      badge_pet:     'rgba(0,255,163,.12)',
      room_fill:     'rgba(0,195,255,.12)',
      raid:          'rgba(255,60,60,.1)',
      trade:         'rgba(155,48,255,.12)',
      custom:        'rgba(0,195,255,.1)',
    };

    let _credits  = 0;
    let _products = [];
    let _selectedProduct = null;
    let _roomFillPrice   = 0;

    // ── Carga inicial ──────────────────────────────────
    (async () => {
      try {
        const [{ user }, { credits }, resP, resO, resB] = await Promise.all([
          AuthAPI.me(),
          CreditsAPI.balance(),
          ProductsAPI.list(),
          ProductsAPI.myOrders(),
          BotsAPI.list().catch(() => ({ bots: [] })),
        ]);

        const products = resP.products || [];
        const orders   = resO.orders   || [];
        const bots     = resB.bots     || [];

        _credits  = credits;
        _products = products;

        // Bienvenida
        document.getElementById('welcome-name').textContent = user.username;
        document.getElementById('home-credits').textContent = credits.toLocaleString();
        document.getElementById('modal-balance').textContent = credits;

        // Avatar de Habbo (si tiene cuenta vinculada)
        loadHabboAvatar(user);

        // Productos
        renderProducts(products);

        // Servicios activos
        renderActiveServices(orders, bots);

        // Pedidos (máximo 5)
        renderOrders(orders.slice(0, 5));
      } catch (err) {
        console.error(err);
      }
    })();

    // ── Servicios y bots activos ───────────────────────
    function renderActiveServices(orders, bots) {
      const activeOrders = orders.filter(o => o.status === 'active' || o.status === 'pending');
      const activeBots   = bots.filter(b => b.status === 'online' || b.status === 'busy');
      const section      = document.getElementById('active-section');
      const list         = document.getElementById('active-list');

      if (!activeOrders.length && !activeBots.length) {
        section.style.display = 'none'; return;
      }
      section.style.display = 'block';

      const now = Date.now();
      const items = [];

      // Bots alquilados activos
      for (const bot of activeBots) {
        const expiresAt  = bot.expires_at ? new Date(bot.expires_at) : null;
        const msLeft     = expiresAt ? expiresAt - now : null;
        const isPending  = bot.status !== 'online';
        items.push({
          icon:     '🤖',
          bg:       'rgba(0,195,255,.12)',
          name:     `Bot: ${bot.name || 'Sin nombre'}`,
          meta:     `habbo.${bot.hotel} · ${bot.duration_label || 'Alquilado'}`,
          status:   isPending ? 'pending' : 'active',
          msLeft,
          endsAt:   expiresAt,
          type:     'bot',
          id:       bot.id,
        });
      }

      // Pedidos de servicios activos
      for (const order of activeOrders) {
        const p        = _products.find(p => p.id === order.product_id);
        const endsAt   = order.ends_at ? new Date(order.ends_at) : null;
        const msLeft   = endsAt ? endsAt - now : null;
        items.push({
          icon:     PRODUCT_ICONS[p?.type] || '📦',
          bg:       ICON_COLORS[p?.type]   || 'rgba(0,195,255,.1)',
          name:     p?.name || order.product_id,
          meta:     `${order.habbo_name} · habbo.${order.hotel}${order.bot_count ? ` · ${order.bot_count} bots` : ''}`,
          status:   order.status,
          msLeft,
          endsAt,
          type:     'order',
          id:       order.id,
        });
      }

      list.innerHTML = items.map(item => {
        const isPending = item.status === 'pending';
        const timeStr   = item.endsAt
          ? formatCountdown(item.msLeft)
          : (isPending ? 'Iniciando…' : 'En curso');
        const isExpiring = item.msLeft !== null && item.msLeft < 3 * 3600_000;
        const pct = item.msLeft !== null && item.endsAt
          ? Math.min(100, Math.max(0, (item.msLeft / (item.endsAt - now + item.msLeft)) * 100))
          : null;

        return `<div class="active-card" id="active-${item.id}">
          <div class="active-icon" style="background:${item.bg}">${item.icon}</div>
          <div class="active-info">
            <div class="active-name">${item.name}</div>
            <div class="active-meta">${item.meta}</div>
            ${pct !== null ? `<div class="active-progress"><div class="active-progress-bar" style="width:${pct.toFixed(1)}%;background:${isExpiring ? 'var(--warning)' : 'var(--success)'};"></div></div>` : ''}
          </div>
          <div class="active-time ${isExpiring ? 'expiring' : ''}" id="time-${item.id}">${timeStr}</div>
          ${item.type === 'bot' ? `<button class="btn-stop" onclick="stopBot('${item.id}')">■ Parar</button>` : ''}
        </div>`;
      }).join('');

      // Actualizar countdowns cada segundo
      clearInterval(window._activeTimer);
      window._activeTimer = setInterval(() => {
        for (const item of items) {
          if (!item.endsAt) continue;
          const ms  = item.endsAt - Date.now();
          const el  = document.getElementById(`time-${item.id}`);
          if (!el) continue;
          if (ms <= 0) {
            el.textContent = 'Finalizado';
            document.getElementById(`active-${item.id}`)?.remove();
          } else {
            el.textContent = formatCountdown(ms);
            el.className   = 'active-time' + (ms < 3 * 3600_000 ? ' expiring' : '');
          }
        }
      }, 1000);
    }

    function formatCountdown(ms) {
      if (ms <= 0) return 'Finalizado';
      const s = Math.floor(ms / 1000);
      const d = Math.floor(s / 86400);
      const h = Math.floor((s % 86400) / 3600);
      const m = Math.floor((s % 3600) / 60);
      const sec = s % 60;
      if (d > 0) return `${d}d ${h}h ${m}m`;
      if (h > 0) return `${h}h ${m}m ${sec}s`;
      return `${m}m ${sec}s`;
    }

    async function stopBot(botId) {
      if (!confirm('¿Detener este bot?')) return;
      try {
        await BotsAPI.stop(botId);
        document.getElementById(`active-${botId}`)?.remove();
        showToast('Bot detenido', 'success');
      } catch (e) { showToast(e.message, 'danger'); }
    }

    function loadHabboAvatar(user) {
      // Intenta cargar avatar con la API de Habbo
      // El username = nick de Habbo
      const img = document.getElementById('habbo-avatar');
      const fallback = document.getElementById('habbo-avatar-fallback');
      if (!user.username) return;
      // headonly=1 → solo la cabeza, encaja mejor en formato horizontal 200×40
      img.src = `https://www.habbo.es/habbo-imaging/avatarimage?user=${encodeURIComponent(user.username)}&headonly=1&size=b&direction=3&head_direction=3`;
      img.onload = () => { img.style.display = 'block'; fallback.style.display = 'none'; };
    }

    // ── Renderizar productos ───────────────────────────
    function renderProducts(list) {
      const grid = document.getElementById('products-grid');
      if (!list.length) {
        grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1;">No hay servicios disponibles ahora mismo.</div>';
        return;
      }
      grid.innerHTML = list.map(p => {
        const imgSrc = p.image_url ? `/api${p.image_url}` : null;
        const banner = imgSrc
          ? `<img class="product-banner" src="${imgSrc}" alt="${p.name}" loading="lazy" />`
          : `<div class="product-banner-fallback" style="background:${ICON_COLORS[p.type] || 'rgba(0,195,255,.1)'}">
               ${PRODUCT_ICONS[p.type] || '✨'}
             </div>`;
        return `
          <div class="product-card" onclick="openOrder('${p.id}')">
            ${banner}
            <div class="product-body">
              <p class="product-name">${p.name}</p>
              <p class="product-desc">${p.description || ''}</p>
              <div class="product-footer">
                <span class="product-price">${p.price} <span>créditos</span></span>
                <button class="btn-order">Pedir</button>
              </div>
            </div>
          </div>`;
      }).join('');
    }

    // ── Renderizar pedidos recientes ───────────────────
    function renderOrders(list) {
      const el = document.getElementById('orders-list');
      if (!list.length) {
        el.innerHTML = `
          <div class="empty-state">
            <svg width="32" height="32" fill="none" stroke="rgba(0,195,255,.3)" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 12h6M9 8h6M9 16h4"/></svg>
            <p>Aún no has hecho ningún pedido.</p>
          </div>`;
        return;
      }
      const statusMap = {
        pending:   { label: 'Pendiente', cls: 'badge-pending' },
        active:    { label: 'Activo',    cls: 'badge-active' },
        completed: { label: 'Completado', cls: 'badge-completed' },
        cancelled: { label: 'Cancelado', cls: 'badge-cancelled' },
        failed:    { label: 'Fallido',   cls: 'badge-cancelled' },
      };
      el.innerHTML = list.map(o => {
        const s   = statusMap[o.status] || { label: o.status, cls: 'badge-pending' };
        const p   = _products.find(p => p.id === o.product_id);
        const icon = PRODUCT_ICONS[p?.type] || '📦';
        const bg   = ICON_COLORS[p?.type]  || 'rgba(0,195,255,.1)';
        const date = new Date(o.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
        return `
          <div class="order-row">
            <div class="order-icon" style="background:${bg}">${icon}</div>
            <div class="order-info">
              <div class="order-name">${p?.name || o.product_id}</div>
              <div class="order-meta">${o.habbo_name} · habbo.${o.hotel} · ${date}</div>
            </div>
            <span class="order-badge ${s.cls}">${s.label}</span>
          </div>`;
      }).join('');
    }

    // ── Modal de pedido ────────────────────────────────
    function updateRoomFillPrice() {
      if (!_selectedProduct || !['room_fill','raid'].includes(_selectedProduct.type)) return;
      const hours = parseInt(document.getElementById('modal-duration').value);
      const bots  = parseInt(document.getElementById('modal-bots').value);
      _roomFillPrice = bots * hours * _selectedProduct.price; // price = cr por bot-hora
      document.getElementById('modal-price').textContent = _roomFillPrice.toLocaleString();
    }

    function openOrder(productId) {
      _selectedProduct = _products.find(p => p.id === productId);
      if (!_selectedProduct) return;
      const p = _selectedProduct;

      // Header: imagen o emoji
      const imgEl   = document.getElementById('modal-product-img');
      const iconFb  = document.getElementById('modal-product-icon-fb');
      if (p.image_url) {
        imgEl.src = `/api${p.image_url}`;
        imgEl.style.display  = 'block';
        iconFb.style.display = 'none';
      } else {
        iconFb.textContent    = PRODUCT_ICONS[p.type] || '✨';
        iconFb.style.background = ICON_COLORS[p.type] || 'rgba(0,195,255,.1)';
        iconFb.style.display  = 'flex';
        imgEl.style.display   = 'none';
      }
      document.getElementById('modal-product-name').textContent = p.name;
      document.getElementById('modal-product-desc').textContent = p.description || '';

      document.getElementById('modal-balance').textContent = _credits.toLocaleString();
      document.getElementById('modal-habbo').value = '';
      document.getElementById('modal-notes').value = '';

      const rfOpts = document.getElementById('modal-roomfill-opts');
      if (p.type === 'room_fill' || p.type === 'raid') {
        rfOpts.style.display = '';
        document.getElementById('modal-room-id').value  = '';
        document.getElementById('modal-duration').value = '1';
        document.getElementById('modal-bots').value     = '5';
        updateRoomFillPrice();
      } else {
        rfOpts.style.display = 'none';
        document.getElementById('modal-price').textContent = p.price.toLocaleString();
      }

      document.getElementById('order-modal').classList.add('open');
    }

    function closeModal() {
      document.getElementById('order-modal').classList.remove('open');
    }

    async function confirmOrder() {
      if (!_selectedProduct) return;
      const hotel     = document.getElementById('modal-hotel').value;
      const habboName = document.getElementById('modal-habbo').value.trim();
      const notes     = document.getElementById('modal-notes').value.trim();

      // Precio real (room_fill/raid usa precio dinámico por bots×horas)
      let actualPrice = _selectedProduct.price;
      let botCount    = null;
      let duration    = null;
      let roomId      = null;
      if (_selectedProduct.type === 'room_fill' || _selectedProduct.type === 'raid') {
        roomId      = document.getElementById('modal-room-id').value.trim() || null;
        duration    = parseInt(document.getElementById('modal-duration').value) * 3600;
        botCount    = parseInt(document.getElementById('modal-bots').value);
        actualPrice = _roomFillPrice;
      }

      if (!habboName) { showToast('Escribe tu nick de Habbo', 'warning'); return; }

      if (_credits < actualPrice) {
        showToast('No tienes suficientes créditos', 'danger');
        closeModal();
        setTimeout(() => { window.location.href = '/tienda'; }, 1200);
        return;
      }

      const btn = document.getElementById('modal-confirm-btn');
      btn.disabled = true; btn.textContent = 'Procesando…';
      try {
        await ProductsAPI.order(_selectedProduct.id, hotel, habboName, notes, botCount, duration, roomId);
        _credits -= actualPrice;
        document.getElementById('home-credits').textContent = _credits.toLocaleString();
        document.getElementById('nav-credits').textContent  = _credits.toLocaleString();
        showToast('¡Pedido realizado!', 'success');
        closeModal();
        // Recargar pedidos
        const { orders } = await ProductsAPI.myOrders();
        renderOrders((orders || []).slice(0, 5));
      } catch (err) {
        showToast(err.message || 'Error al procesar el pedido', 'danger');
      }
      btn.disabled = false; btn.textContent = 'Confirmar pedido';
    }

    // Cerrar modal al hacer clic fuera
    document.getElementById('order-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeModal();
    });

    // CSS spinner keyframe (inline)
    const style = document.createElement('style');
    style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
    document.head.appendChild(style);
  </script>
</DashLayout>
