---
import DashLayout from '../layouts/DashLayout.astro';
---
<DashLayout title="Dashboard" activePage="dashboard">
  <style>
    .page-header { margin-bottom: 1.75rem; }
    .page-header h1 { font-family:'Orbitron',sans-serif; font-size:1.3rem; font-weight:700; }
    .page-header p { color:var(--text-muted); font-size:.88rem; margin-top:.2rem; }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4,1fr);
      gap: 1rem;
      margin-bottom: 1.75rem;
    }
    .stat-card { padding:1.25rem 1.5rem; }
    .stat-icon {
      width:38px; height:38px; border-radius:10px;
      display:flex; align-items:center; justify-content:center;
      margin-bottom:.65rem;
    }
    .icon-blue   { background:rgba(0,195,255,.12); color:var(--blue-primary); }
    .icon-purple { background:rgba(155,48,255,.12); color:var(--purple-primary); }
    .icon-green  { background:rgba(0,255,163,.12); color:var(--success); }
    .icon-yellow { background:rgba(255,190,0,.12); color:var(--warning); }
    .stat-val { font-family:'Orbitron',sans-serif; font-size:1.55rem; font-weight:700; }
    .stat-lbl { font-size:.75rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.8px; margin-top:.15rem; }
    .stat-ch  { font-size:.74rem; margin-top:.4rem; display:flex; align-items:center; gap:.25rem; }
    .stat-ch.up   { color:var(--success); }
    .stat-ch.down { color:var(--danger); }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr 330px;
      gap: 1.5rem;
    }

    .section-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem; }
    .section-title { font-family:'Orbitron',sans-serif; font-size:.85rem; font-weight:700; }

    .bot-row { display:flex; align-items:center; gap:1rem; padding:.8rem 0; border-bottom:1px solid rgba(255,255,255,.04); }
    .bot-row:last-of-type { border-bottom:none; }
    .bot-av-wrap { position:relative; flex-shrink:0; }
    .bot-av { width:40px; height:40px; border-radius:10px; background:rgba(0,195,255,.08); border:1px solid var(--border-glow); display:flex; align-items:center; justify-content:center; overflow:hidden; }
    .bot-dot { position:absolute; bottom:-2px; right:-2px; width:10px; height:10px; border-radius:50%; border:2px solid var(--bg-dark); }
    .dot-on  { background:var(--success); }
    .dot-off { background:var(--text-muted); }
    .dot-busy{ background:var(--warning); }
    .bot-info { flex:1; min-width:0; }
    .bot-name { font-weight:600; font-size:.88rem; }
    .bot-meta { font-size:.74rem; color:var(--text-muted); margin-top:.1rem; }
    .bot-acts { display:flex; gap:.4rem; }

    /* credit card */
    .credit-card {
      background: linear-gradient(135deg,rgba(0,120,255,.2),rgba(130,0,255,.3));
      border: 1px solid rgba(155,48,255,.3);
      border-radius:14px; padding:1.4rem; position:relative; overflow:hidden;
      margin-bottom:1rem;
    }
    .credit-card::before {
      content:''; position:absolute; top:-40px; right:-40px;
      width:160px; height:160px; border-radius:50%;
      background:radial-gradient(circle,rgba(155,48,255,.25) 0%,transparent 70%);
    }
    .credit-lbl { font-size:.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:.25rem; }
    .credit-amt { font-family:'Orbitron',sans-serif; font-size:2rem; font-weight:800; }
    .credit-sub { font-size:.75rem; color:var(--text-muted); margin-top:.15rem; }

    /* quick actions */
    .quick-grid { display:grid; grid-template-columns:1fr 1fr; gap:.6rem; }
    .quick-btn {
      display:flex; flex-direction:column; align-items:center; gap:.4rem;
      padding:.85rem; background:var(--bg-card);
      border:1px solid var(--border-glow); border-radius:10px;
      color:var(--text-secondary); text-decoration:none;
      font-size:.78rem; font-weight:500; cursor:pointer;
      transition:all .2s;
    }
    .quick-btn:hover { border-color:var(--blue-primary); color:var(--blue-primary); background:rgba(0,195,255,.06); }
    .quick-ic { width:34px; height:34px; border-radius:9px; display:flex; align-items:center; justify-content:center; }

    /* activity */
    .act-item { display:flex; align-items:flex-start; gap:.7rem; padding:.6rem 0; border-bottom:1px solid rgba(255,255,255,.04); }
    .act-item:last-child { border-bottom:none; }
    .act-ic { width:28px; height:28px; border-radius:7px; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:.8rem; }
    .act-txt { flex:1; font-size:.8rem; color:var(--text-secondary); line-height:1.4; }
    .act-txt strong { color:var(--text-primary); }
    .act-time { font-size:.68rem; color:var(--text-muted); margin-top:.1rem; }

    /* verify banner */
    .verify-banner {
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      padding:.9rem 1.25rem; margin-bottom:1.5rem;
    }
    .verify-banner p { font-size:.86rem; color:var(--text-secondary); }

    /* hamburger */
    .hamburger { display:none; background:none; border:none; color:var(--text-secondary); cursor:pointer; padding:.35rem; }

    @media (max-width:1100px) { .content-grid { grid-template-columns:1fr; } .stats-grid { grid-template-columns:repeat(2,1fr); } }
    @media (max-width:768px)  { .stats-grid { grid-template-columns:repeat(2,1fr); gap:.75rem; } .hamburger { display:flex; } }
  </style>

  <!-- Verification banner (Habbo-window style alert) -->
  <div class="hb-window verify-banner" id="verify-banner" style="background:rgba(10,30,10,0.6);border-color:#000;">
    <div class="hb-window-title" style="background:linear-gradient(90deg,#3a2a00,#1a1000);margin:-1px -1px 0;">
      <h3>⚠ Verificación pendiente</h3>
      <span class="hb-close" onclick="document.getElementById('verify-banner').remove()">✕</span>
    </div>
    <div style="padding:.8rem 1.1rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
      <p>Vincula tu cuenta de Habbo para desbloquear todas las funciones.</p>
      <a href="/verificar" class="hb-btn" style="white-space:nowrap;background:linear-gradient(180deg,#6a4a00,#3a2500);">Verificar ahora</a>
    </div>
  </div>

  <!-- Page header -->
  <div class="page-header">
    <h1>¡Hola, <span class="gradient-text">Rafa</span>! 👋</h1>
    <p>Resumen de tu actividad en HabboBots.</p>
  </div>

  <!-- Stats -->
  <div class="stats-grid">
    <div class="card stat-card">
      <div class="stat-icon icon-blue">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M12 11V5"/><circle cx="12" cy="4" r="1"/></svg>
      </div>
      <div class="stat-val neon-blue">3</div>
      <div class="stat-lbl">Bots activos</div>
      <div class="stat-ch up">▲ +1 este mes</div>
    </div>
    <div class="card stat-card">
      <div class="stat-icon icon-purple">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
      </div>
      <div class="stat-val neon-purple">1,240</div>
      <div class="stat-lbl">Créditos</div>
      <div class="stat-ch up">▲ +500 comprados</div>
    </div>
    <div class="card stat-card">
      <div class="stat-icon icon-green">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <div class="stat-val" style="color:var(--success);">99.2%</div>
      <div class="stat-lbl">Uptime bots</div>
      <div class="stat-ch up">▲ Excelente</div>
    </div>
    <div class="card stat-card">
      <div class="stat-icon icon-yellow">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      </div>
      <div class="stat-val" style="color:var(--warning);">2</div>
      <div class="stat-lbl">Hoteles</div>
      <div class="stat-ch" style="color:var(--text-muted);">.es / .com</div>
    </div>
  </div>

  <!-- Content grid -->
  <div class="content-grid">
    <!-- Bots list — Habbo window style -->
    <div class="hb-window">
      <div class="hb-window-title">
        <h3>Mis Bots</h3>
        <a href="/bots" class="hb-btn" style="font-size:.75rem;padding:.25rem .6rem;">Ver todos</a>
      </div>
      <div class="hb-window-body">
        <div class="bot-row">
          <div class="bot-av-wrap">
            <div class="bot-av">
              <img src="https://sandbox.habbo.com/habbo-imaging/avatarimage?figure=hd-180-1369.ch-210-1408.lg-4315&direction=3&head_direction=3&gesture=nrm&headonly=1&size=s" style="height:36px;" alt="bot" onerror="this.src='https://ui-avatars.com/api/?name=B1&background=0080ff&color=fff&size=36'" />
            </div>
            <span class="bot-dot dot-on"></span>
          </div>
          <div class="bot-info">
            <div class="bot-name">HabboBot_Alpha</div>
            <div class="bot-meta">habbo.es · <span style="color:var(--success)">En línea</span> · Sala: La Terraza</div>
          </div>
          <div class="bot-acts">
            <span class="badge badge-success">Activo</span>
            <a href="/bots" class="hb-btn hb-btn-ghost" style="font-size:.75rem;padding:.25rem .6rem;">Gestionar</a>
          </div>
        </div>

        <div class="bot-row">
          <div class="bot-av-wrap">
            <div class="bot-av">
              <img src="https://sandbox.habbo.com/habbo-imaging/avatarimage?figure=hd-180-1.ch-210-1408.lg-280&direction=3&head_direction=3&gesture=nrm&headonly=1&size=s" style="height:36px;" alt="bot" onerror="this.src='https://ui-avatars.com/api/?name=B2&background=9b30ff&color=fff&size=36'" />
            </div>
            <span class="bot-dot dot-on"></span>
          </div>
          <div class="bot-info">
            <div class="bot-name">TradeBot_ES</div>
            <div class="bot-meta">habbo.es · <span style="color:var(--success)">En línea</span> · Sala: Mercado</div>
          </div>
          <div class="bot-acts">
            <span class="badge badge-success">Activo</span>
            <a href="/bots" class="hb-btn hb-btn-ghost" style="font-size:.75rem;padding:.25rem .6rem;">Gestionar</a>
          </div>
        </div>

        <div class="bot-row">
          <div class="bot-av-wrap">
            <div class="bot-av" style="font-size:1.3rem;">🤖</div>
            <span class="bot-dot dot-busy"></span>
          </div>
          <div class="bot-info">
            <div class="bot-name">FarmBot_COM</div>
            <div class="bot-meta">habbo.com · <span style="color:var(--warning)">Ocupado</span> · Farmeo activo</div>
          </div>
          <div class="bot-acts">
            <span class="badge badge-warning">Ocupado</span>
            <a href="/bots" class="hb-btn hb-btn-ghost" style="font-size:.75rem;padding:.25rem .6rem;">Gestionar</a>
          </div>
        </div>

        <div style="margin-top:1rem;">
          <a href="/bots" class="hb-btn hb-btn-purple w-full" style="width:100%;justify-content:center;display:flex;gap:.5rem;align-items:center;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Contratar nuevo bot
          </a>
        </div>
      </div>
    </div>

    <!-- Right column -->
    <div style="display:flex;flex-direction:column;gap:1.25rem;">

      <!-- Credits — Habbo window -->
      <div class="hb-window">
        <div class="hb-window-title" style="background:linear-gradient(90deg,#1a0650,#0a2a6e);">
          <h3>💎 Mis créditos</h3>
          <span class="hb-minimize">–</span>
        </div>
        <div class="hb-window-body" style="background:linear-gradient(135deg,rgba(0,120,255,.1),rgba(130,0,255,.15));position:relative;overflow:hidden;">
          <div style="position:absolute;top:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,rgba(155,48,255,.2) 0%,transparent 70%);"></div>
          <div style="position:relative;z-index:1;">
            <div class="credit-lbl">Saldo disponible</div>
            <div class="credit-amt gradient-text">1,240</div>
            <div class="credit-sub">créditos HabboBots</div>
            <div style="margin-top:1rem;">
              <div class="progress-bar"><div class="progress-fill" style="width:62%;"></div></div>
              <div style="display:flex;justify-content:space-between;margin-top:.35rem;font-size:.7rem;color:var(--text-muted);">
                <span>1,240 / 2,000</span><span>Plan Básico</span>
              </div>
            </div>
            <a href="/tienda" class="hb-btn hb-btn-purple" style="width:100%;display:flex;align-items:center;justify-content:center;gap:.5rem;margin-top:1rem;">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Recargar créditos
            </a>
          </div>
        </div>
      </div>

      <!-- Quick actions — Habbo window -->
      <div class="hb-window">
        <div class="hb-window-title"><h3>Acciones rápidas</h3></div>
        <div class="hb-window-body">
          <div class="quick-grid">
            <a href="/bots" class="quick-btn">
              <div class="quick-ic icon-blue"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M12 11V5"/><circle cx="12" cy="4" r="1"/></svg></div>
              Nuevo bot
            </a>
            <a href="/tienda" class="quick-btn">
              <div class="quick-ic icon-purple"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
              Comprar
            </a>
            <a href="/verificar" class="quick-btn">
              <div class="quick-ic icon-yellow"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              Verificar
            </a>
            <a href="/perfil" class="quick-btn">
              <div class="quick-ic icon-green"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
              Perfil
            </a>
          </div>
        </div>
      </div>

      <!-- Activity — Habbo window -->
      <div class="hb-window">
        <div class="hb-window-title"><h3>Actividad reciente</h3></div>
        <div class="hb-window-body">
          <div class="act-item">
            <div class="act-ic icon-green">✓</div>
            <div class="act-txt"><strong>HabboBot_Alpha</strong> se conectó<div class="act-time">hace 12 min</div></div>
          </div>
          <div class="act-item">
            <div class="act-ic icon-purple">💳</div>
            <div class="act-txt">Compraste <strong>500 créditos</strong><div class="act-time">hace 2 horas</div></div>
          </div>
          <div class="act-item">
            <div class="act-ic icon-blue">🤖</div>
            <div class="act-txt"><strong>FarmBot_COM</strong> inició sesión<div class="act-time">hace 4 horas</div></div>
          </div>
          <div class="act-item">
            <div class="act-ic icon-yellow">⚠</div>
            <div class="act-txt"><strong>TradeBot_ES</strong> desconectado por el hotel<div class="act-time">ayer 22:14</div></div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script is:inline slot="scripts">
    // Carga datos reales del backend
    (async () => {
      try {
        // Stats globales
        const stats = await StatsAPI.overview();
        document.querySelector('.stat-val.neon-blue').textContent    = stats.bots.online;
        document.querySelector('.stat-val.neon-purple').textContent  = stats.credits.balance.toLocaleString();

        // Nombre de usuario en el saludo
        const { user } = await UsersAPI.me();
        const greet = document.querySelector('.page-header h1');
        if (greet) greet.innerHTML = `¡Hola, <span class="gradient-text">${user.username}</span>! 👋`;

        // Créditos en la tarjeta
        const creditAmt = document.querySelector('.credit-amt');
        if (creditAmt) creditAmt.textContent = stats.credits.balance.toLocaleString();

      } catch (err) {
        // Si el token expiró, logout
        if (err.status === 401) AuthAPI.logout();
      }

      // Carga lista de bots
      try {
        const { bots } = await BotsAPI.list();
        const botsCount = document.querySelector('.stat-val.neon-blue');
        if (botsCount) botsCount.textContent = bots.filter(b => b.status === 'online').length;
      } catch {}
    })();
  </script>
</DashLayout>
