---
export interface Props {
  title?: string;
  activePage?: string;
}
const { title = 'Dashboard', activePage = 'dashboard' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — HabboBots</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdn.socket.io/4.7.5/socket.io.min.js" is:inline></script>
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#00c3ff" />
  <slot name="head" />
</head>
<body>
  <div class="bg-grid"></div>
  <div class="bg-glow-1"></div>
  <div class="bg-glow-2"></div>

  <div class="page-wrapper">

    <!-- ══ NAVBAR ══ -->
    <nav class="navbar">
      <div style="display:flex;align-items:center;gap:1rem;">
        <button class="hamburger" onclick="toggleSidebar()" aria-label="Menú">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <a href="/home" class="navbar-brand" style="padding:0;overflow:hidden;display:flex;align-items:stretch;">
          <img src="/assets/images/logo.gif" alt="HabboBots" style="width:200px;height:40px;object-fit:contain;display:block;" />
        </a>
      </div>

      <ul class="navbar-nav">
        <li><a href="/home"       class={activePage === 'home'       ? 'active' : ''}>Inicio</a></li>
        <li><a href="/bots"       class={activePage === 'bots'       ? 'active' : ''}>Mis Bots</a></li>
        <li><a href="/tienda"     class={activePage === 'tienda'     ? 'active' : ''}>Tienda</a></li>
        <li><a href="/servicios"  class={activePage === 'servicios'  ? 'active' : ''}>Servicios</a></li>
        <li id="nav-admin-link" style="display:none;"><a href="/dashboard" class={activePage === 'dashboard' ? 'active' : ''}>Admin</a></li>
        <li><a href="/perfil"     class={activePage === 'perfil'     ? 'active' : ''}>Perfil</a></li>
      </ul>

      <div class="navbar-actions" style="display:flex;align-items:center;gap:.75rem;">
        <div style="display:flex;align-items:center;gap:.5rem;padding:.35rem .85rem;background:rgba(155,48,255,.12);border:1px solid rgba(155,48,255,.25);border-radius:50px;font-size:.82rem;color:var(--purple-primary);font-weight:600;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
          <span id="nav-credits">1,240</span> créditos
        </div>
        <div class="notif-wrap" style="position:relative;display:inline-flex;">
          <button id="notif-btn" style="background:none;border:none;color:var(--text-secondary);cursor:pointer;display:flex;padding:.35rem;" onclick="toggleNotifPanel()">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </button>
          <span id="notif-badge" style="display:none;position:absolute;top:-4px;right:-4px;min-width:16px;height:16px;border-radius:50%;background:var(--danger);font-size:.6rem;font-weight:700;color:#fff;align-items:center;justify-content:center;border:2px solid var(--bg-dark);"></span>
          <!-- Panel de notificaciones -->
          <div id="notif-panel" style="display:none;position:absolute;top:calc(100% + .5rem);right:0;width:320px;background:#0d1428;border:1px solid rgba(0,195,255,.2);border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:300;overflow:hidden;">
            <div style="padding:.75rem 1rem;border-bottom:1px solid rgba(0,195,255,.1);display:flex;align-items:center;justify-content:space-between;">
              <span style="font-weight:600;font-size:.85rem;">Notificaciones</span>
              <button onclick="markAllRead()" style="background:none;border:none;color:var(--blue-primary);font-size:.75rem;cursor:pointer;">Marcar todas leídas</button>
            </div>
            <div id="notif-list" style="max-height:320px;overflow-y:auto;padding:.5rem 0;">
              <div style="text-align:center;padding:1.5rem;color:var(--text-muted);font-size:.82rem;">Sin notificaciones nuevas</div>
            </div>
          </div>
        </div>
        <a href="/perfil" style="display:flex;align-items:center;gap:.5rem;text-decoration:none;" id="nav-user-link">
          <img id="nav-habbo-avatar"
               src="/assets/images/avatar-default.png"
               style="width:36px;height:36px;border-radius:50%;border:2px solid var(--border-glow);object-fit:cover;background:rgba(0,0,0,.3);"
               alt="Avatar" />
          <span style="font-size:.85rem;color:var(--text-secondary);" id="nav-username">—</span>
        </a>
      </div>
    </nav>

    <!-- ══ LAYOUT ══ -->
    <div class="dash-layout">

      <!-- SIDEBAR -->
      <aside class="sidebar">
        <p class="sidebar-section-label">General</p>
        <ul class="sidebar-menu">
          <li><a href="/home" class={activePage === 'home' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Inicio
          </a></li>
          <li><a href="/servicios" class={activePage === 'servicios' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Servicios
          </a></li>
          <li><a href="/tienda" class={activePage === 'tienda' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            Tienda
          </a></li>
          <li><a href="/bots" class={activePage === 'bots' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M12 11V5"/><circle cx="12" cy="4" r="1"/><path d="M8 11V8h8v3"/></svg>
            Mis Bots
          </a></li>
          <li><a href="/mi-bot" class={activePage === 'mi-bot' ? 'active' : ''} style="padding-left:2.2rem;">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Controlar bot
          </a></li>
          <li><a href="/stats" class={activePage === 'stats' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Estadísticas
          </a></li>
          <!-- Solo visible para admins (JS lo muestra) -->
          <li id="sidebar-admin-link" style="display:none;"><a href="/dashboard" class={activePage === 'dashboard' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Admin Panel
          </a></li>
          <li id="sidebar-botcontrol-link" style="display:none;"><a href="/botcontrol" class={activePage === 'botcontrol' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M12 11V5"/><circle cx="12" cy="4" r="1"/><path d="M8 11V8h8v3"/><line x1="7" y1="15" x2="7" y2="17"/><line x1="12" y1="15" x2="12" y2="17"/><line x1="17" y1="15" x2="17" y2="17"/></svg>
            Bot Control
          </a></li>
          <li id="sidebar-metricas-link" style="display:none;"><a href="/metricas" class={activePage === 'metricas' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Métricas
          </a></li>
          <li id="sidebar-tickets-admin-link" style="display:none;"><a href="/admin-tickets" class={activePage === 'admin-tickets' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Tickets admin
          </a></li>
          <li id="sidebar-cupones-link" style="display:none;"><a href="/admin-cupones" class={activePage === 'admin-cupones' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            Cupones
          </a></li>
        </ul>

        <p class="sidebar-section-label" style="margin-top:.75rem;">Cuenta</p>
        <ul class="sidebar-menu">
          <li><a href="/perfil" class={activePage === 'perfil' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Mi Perfil
          </a></li>
          <li><a href="/verificar" class={activePage === 'verificar' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Verificar Habbo
          </a></li>
          <li><a href="/ajustes" class={activePage === 'ajustes' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Ajustes
          </a></li>
        </ul>

        <p class="sidebar-section-label" style="margin-top:.75rem;">Soporte</p>
        <ul class="sidebar-menu">
          <li><a href="/afiliados" class={activePage === 'afiliados' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Afiliados
          </a></li>
          <li><a href="/soporte" class={activePage === 'soporte' ? 'active' : ''}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Mis tickets
          </a></li>
          <li><a href="/status" target="_blank">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Estado del sistema
          </a></li>
          <li><a href="#" onclick="showToast('Abriendo Discord…','info')">
            <svg width="16" height="16" viewBox="0 0 71 55" fill="currentColor"><path d="M60.1 4.9A58.55 58.55 0 0 0 45.6.3a40.2 40.2 0 0 0-1.8 3.6 54.3 54.3 0 0 0-16.2 0A38.6 38.6 0 0 0 25.8.3 58.46 58.46 0 0 0 11.3 4.9C1.6 19.2-.98 33.1.31 46.8a59.09 59.09 0 0 0 18 9.1 42.07 42.07 0 0 0 3.7-6 38.35 38.35 0 0 1-5.8-2.8c.49-.35.97-.72 1.43-1.1a42.1 42.1 0 0 0 35.68 0c.47.38.95.75 1.43 1.1a38.46 38.46 0 0 1-5.82 2.8 41.94 41.94 0 0 0 3.7 6 58.89 58.89 0 0 0 18.02-9.1C72.48 30.9 68.47 17.1 60.1 4.9Z"/></svg>
            Discord
          </a></li>
          <li><a href="/" onclick="handleLogout(); return false;">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Cerrar sesión
          </a></li>
        </ul>
      </aside>

      <!-- MAIN CONTENT SLOT -->
      <main class="dash-content">
        <slot />
      </main>

    </div>
  </div>

  <script is:inline src="/js/main.js"></script>
  <script is:inline src="/js/api.js"></script>
  <script is:inline>
    // Guard: redirige al login si no hay token
    if (!Auth.isLoggedIn()) window.location.href = '/';

    // ── Socket.io — notificaciones en tiempo real ──
    let _socket = null;
    let _unreadNotifs = [];

    function initSocketConnection(userId) {
      if (!window.io) return;
      _socket = io({ path: '/socket.io', transports: ['websocket','polling'] });
      _socket.on('connect', () => { _socket.emit('join', userId); });

      _socket.on('notification', (notif) => {
        addNotification(notif);
        showToast(notif.title + (notif.message ? ': ' + notif.message : ''), notif.type || 'info');
      });

      _socket.on('pending_notifications', (notifs) => {
        notifs.forEach(n => addNotification(n));
      });

      _socket.on('credits_update', ({ balance }) => {
        const el = document.getElementById('nav-credits');
        if (el) el.textContent = balance.toLocaleString();
      });

      _socket.on('order_update', (order) => {
        // Si la página tiene una función de recarga de pedidos, llamarla
        if (typeof window.onOrderUpdate === 'function') window.onOrderUpdate(order);
      });
    }

    function addNotification(notif) {
      _unreadNotifs.unshift(notif);
      renderNotifBadge();
      renderNotifList();
    }

    function renderNotifBadge() {
      const badge = document.getElementById('notif-badge');
      const count = _unreadNotifs.filter(n => !n.read).length;
      if (count > 0) {
        badge.textContent = count > 9 ? '9+' : count;
        badge.style.display = 'flex';
      } else {
        badge.style.display = 'none';
      }
    }

    function renderNotifList() {
      const list = document.getElementById('notif-list');
      if (_unreadNotifs.length === 0) {
        list.innerHTML = '<div style="text-align:center;padding:1.5rem;color:var(--text-muted);font-size:.82rem;">Sin notificaciones nuevas</div>';
        return;
      }
      const typeIcon = { success: '✅', danger: '❌', warning: '⚠️', info: 'ℹ️' };
      list.innerHTML = _unreadNotifs.slice(0,10).map(n => `
        <div style="padding:.65rem 1rem;border-bottom:1px solid rgba(255,255,255,.04);display:flex;gap:.75rem;align-items:flex-start;">
          <span style="font-size:1rem;flex-shrink:0;">${typeIcon[n.type] || 'ℹ️'}</span>
          <div style="flex:1;">
            <div style="font-size:.82rem;font-weight:600;color:#fff;">${n.title}</div>
            ${n.message ? `<div style="font-size:.75rem;color:var(--text-muted);margin-top:.15rem;">${n.message}</div>` : ''}
          </div>
        </div>
      `).join('');
    }

    function toggleNotifPanel() {
      const panel = document.getElementById('notif-panel');
      panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    }

    function markAllRead() {
      _unreadNotifs = _unreadNotifs.map(n => ({ ...n, read: 1 }));
      renderNotifBadge();
      renderNotifList();
      document.getElementById('notif-panel').style.display = 'none';
    }

    // Cerrar panel al hacer clic fuera
    document.addEventListener('click', (e) => {
      const wrap = document.querySelector('.notif-wrap');
      if (wrap && !wrap.contains(e.target)) {
        const panel = document.getElementById('notif-panel');
        if (panel) panel.style.display = 'none';
      }
    });

    function handleLogout() {
      showToast('Cerrando sesión…', 'warning');
      setTimeout(() => { AuthAPI.logout(); }, 700);
    }

    // Carga usuario: créditos + guard Habbo + enlace admin + socket
    (async () => {
      try {
        const [{ credits }, { user }, habboData] = await Promise.all([
          CreditsAPI.balance(),
          AuthAPI.me(),
          HabboAPI.accounts(),
        ]);

        // Conectar socket.io con el userId real
        initSocketConnection(user.id);

        const el = document.getElementById('nav-credits');
        if (el) el.textContent = credits.toLocaleString();

        // ── Avatar e identificador del usuario en la navbar ──────────
        const navUsername = document.getElementById('nav-username');
        const navAvatar   = document.getElementById('nav-habbo-avatar');
        if (navUsername) navUsername.textContent = user.username || user.email?.split('@')[0];

        // Intentar avatar Habbo del hotel principal
        const habboAccount = habboData?.accounts?.[0];
        if (navAvatar && habboAccount) {
          const hotel   = habboAccount.hotel || 'es';
          const habboName = habboAccount.habbo_name || user.username;
          const domain  = hotel === 'com' ? 'com' : hotel === 'com.br' ? 'com.br' : 'es';
          navAvatar.src = `https://www.habbo.${domain}/habbo-imaging/avatarimage?user=${encodeURIComponent(habboName)}&direction=2&head_direction=3&gesture=sml&headonly=1&size=l`;
          navAvatar.onerror = () => { navAvatar.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(user.username||'?')}&background=0d1428&color=00c3ff&size=64&bold=true&rounded=true`; };
        } else if (navAvatar) {
          navAvatar.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(user.username||'?')}&background=0d1428&color=00c3ff&size=64&bold=true&rounded=true`;
        }

        // Guard: si no tiene Habbo verificado → ir a verificar (excepto si ya está ahí)
        const sinHabbo = !habboData.accounts || habboData.accounts.length === 0;
        const enVerificar = window.location.pathname === '/verificar-habbo';
        if (sinHabbo && !enVerificar) {
          window.location.href = '/verificar-habbo';
          return;
        }

        // Mostrar enlace admin solo si el rol lo permite
        if (user.role === 'admin' || user.role === 'moderator') {
          const nav        = document.getElementById('nav-admin-link');
          const sidebar    = document.getElementById('sidebar-admin-link');
          const botctrl    = document.getElementById('sidebar-botcontrol-link');
          const metricas   = document.getElementById('sidebar-metricas-link');
          const tktAdmin   = document.getElementById('sidebar-tickets-admin-link');
          const cupones    = document.getElementById('sidebar-cupones-link');
          if (nav)      nav.style.display      = '';
          if (sidebar)  sidebar.style.display  = '';
          if (botctrl)  botctrl.style.display  = '';
          if (metricas) metricas.style.display  = '';
          if (tktAdmin) tktAdmin.style.display  = '';
          if (cupones)  cupones.style.display   = '';
        }
      } catch {}
    })();
  </script>
  <slot name="scripts" />

  <!-- ── PWA: Service Worker + Push ──────────────────────────────── -->
  <script is:inline>
  (function registerPWA() {
    if (!('serviceWorker' in navigator)) return;
    navigator.serviceWorker.register('/sw.js').then(reg => {
      // Suscribirse a push si tenemos VAPID key y permiso
      if (!('PushManager' in window)) return;
      Notification.requestPermission().then(async perm => {
        if (perm !== 'granted') return;
        try {
          const { publicKey } = await PushAPI_HB.vapidKey();
          if (!publicKey) return;
          const sub = await reg.pushManager.subscribe({
            userVisibleOnly:      true,
            applicationServerKey: publicKey,
          });
          await PushAPI_HB.subscribe(sub.toJSON());
        } catch (e) { /* VAPID no configurado, silencioso */ }
      });
    }).catch(() => {});
  })();
  </script>
</body>
</html>
